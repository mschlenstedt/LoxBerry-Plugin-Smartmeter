# Auto detect text files and perform LF normalization
* text=auto

# LoxBerry executes these files directly; CRLF breaks Linux shebang lines.
*.pl  text eol=lf
*.pm  text eol=lf
*.cgi text eol=lf
*.sh  text eol=lf

# Custom for Visual Studio
*.cs     diff=csharp

# Standard to msysgit
*.doc	 diff=astextplain
*.DOC	 diff=astextplain
*.docx diff=astextplain
*.DOCX diff=astextplain
*.dot  diff=astextplain
*.DOT  diff=astextplain
*.pdf  diff=astextplain
*.PDF	 diff=astextplain
*.rtf	 diff=astextplain
*.RTF	 diff=astextplain

# Exclude development-only files from GitHub source archives used by LoxBerry.
.github/ export-ignore
AGENTS.md export-ignore
docs/release-process.md export-ignore
docs/local-builds.md export-ignore
docs/vzlogger-implementation-plan.md export-ignore
Tests/ export-ignore
tests/ export-ignore
test/ export-ignore
